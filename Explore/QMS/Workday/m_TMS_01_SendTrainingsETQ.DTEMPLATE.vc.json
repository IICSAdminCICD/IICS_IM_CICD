        "helperCodeSnippet" : "// TODO: Declare static and non-static partition-level variables and functions here.\n// For example,\n//\n// static int countNullRows;   // Counts the number of output rows across all partitions that contains null values.\n// int partCountNullRows;      // Counts the number of output rows in this partition that contains null values.\n//\n// static Object lock = new Object();   // Lock to synchronize countNullRows.\n\n\npublic static String callSoapWebService(int payloadID, String inputString, String SOA_ENDPOINT, String SOAP_ACTION) throws Exception {\n\t\t\t// Construir el mensaje SOAP XML\n\t\t\tString soapXml = buildSoapRequest(payloadID,inputString);\n\n\t\t\t// Crear conexión HTTP\n\t\t\tURL url = new URL(SOA_ENDPOINT);\n\t\t\tHttpURLConnection connection = (HttpURLConnection) url.openConnection();\n\n\t\t\t// Configurar conexión\n\t\t\tconnection.setRequestMethod(\"POST\");\n\t\t\tconnection.setDoOutput(true);\n\t\t\tconnection.setDoInput(true);\n\t\t\tconnection.setRequestProperty(\"Content-Type\", \"text/xml; charset=utf-8\");\n\t\t\tif (!SOAP_ACTION.isEmpty()) {\n\t\t\t\tconnection.setRequestProperty(\"SOAPAction\", SOAP_ACTION);\n\t\t\t}\n\n\t\t\t// Enviar el mensaje SOAP\n\t\t\ttry (OutputStream os = connection.getOutputStream()) {\n\t\t\t\tbyte[] b = soapXml.getBytes(\"UTF-8\");\n\t\t\t\tos.write(b);\n\t\t\t\tos.flush();\n\t\t\t}\n\n\t\t\t// Leer la respuesta\n\t\t\tint responseCode = connection.getResponseCode();\n\t\t\tBufferedReader br;\n\t\t\tif (responseCode >= 200 && responseCode < 300) {\n\t\t\t\tbr = new BufferedReader(new InputStreamReader(connection.getInputStream()));\n\t\t\t} else {\n\t\t\t\tbr = new BufferedReader(new InputStreamReader(connection.getErrorStream()));\n\t\t\t}\n\n\t\t\tStringBuilder response = new StringBuilder();\n\t\t\tString line;\n\t\t\twhile ((line = br.readLine()) != null) {\n\t\t\t\tresponse.append(line);\n\t\t\t}\n\t\t\tbr.close();\n\n\t\t\t\n\t\t\t\treturn responseCode +\" \"+ response.toString();\n\t\t\t\n\t\t}\n\nprivate static String buildSoapRequest(int logID, String inputString) {\n\t\t    String namespace = \"http://services.informatica.com/rt/SDasInsertRecordsETQ\";\n\t\t    String prefix = \"sdas\";\n\n\t\t    return \"<?xml version=\\\"1.0\\\" encoding=\\\"utf-8\\\"?>\"\n\t\t            + \"<soapenv:Envelope xmlns:soapenv=\\\"http://schemas.xmlsoap.org/soap/envelope/\\\" xmlns:\" + prefix + \"=\\\"\" + namespace + \"\\\">\"\n\t\t            + \"<soapenv:Header/>\"\n\t\t            + \"<soapenv:Body>\"\n\t\t            + \"<\" + prefix + \":SDasInsertRecordsETQRequest>\"\n\t\t            + \"<in_PayloadMessage><![CDATA[\" + inputString + \"]]></in_PayloadMessage>\"\n                    + \"<in_LogID>\" + logID + \"</in_LogID>\"\n\t\t            + \"</\" + prefix + \":SDasInsertRecordsETQRequest>\"\n\t\t            + \"</soapenv:Body>\"\n\t\t            + \"</soapenv:Envelope>\";\n\t\t}\n\n\n",
